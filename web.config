<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <staticContent>
            <clientCache cacheControlMode="DisableCache" />
            <remove fileExtension=".html" />
            <mimeMap fileExtension=".html" mimeType="text/html; charset=utf-8" />
        </staticContent>

        <!--
            HTTPS redirect via Cloudflare's CF-Visitor header.
            Cloudflare's edge does HTTPS termination and forwards to cloudflared
            (then to IIS) over plain HTTP. The original scheme is conveyed in
            the CF-Visitor header as JSON: {"scheme":"http"} or {"scheme":"https"}.
            When the original visitor came in over HTTP, redirect them to HTTPS.
            This keeps us secure even if Cloudflare's "Always Use HTTPS" toggle
            is off in the dashboard.
        -->
        <rewrite>
            <rules>
                <rule name="Redirect HTTP to HTTPS via CF-Visitor" stopProcessing="true">
                    <match url=".*" />
                    <conditions logicalGrouping="MatchAny">
                        <add input="{HTTP_CF_VISITOR}" pattern='^\{.*"scheme":"http".*\}$' />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:0}" redirectType="Permanent" appendQueryString="true" />
                </rule>

                <!--
                    Reverse-proxy api.greencommllc.com -> dotnet on
                    127.0.0.1:5099 via ARR. Cloudflare/cloudflared sends
                    requests for the api hostname to this IIS site (it's bound
                    on :80 and :8765 for both the public and the cloudflared
                    backplane); this rule catches them and forwards to the
                    .NET minimal API. Must come before the admin-console
                    rules so the api hostname pre-empts everything else.
                -->
                <rule name="API host reverse-proxy to dotnet" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{HTTP_HOST}" pattern="^api\.greencommllc\.com$" />
                    </conditions>
                    <action type="Rewrite" url="http://127.0.0.1:5099/{R:1}" />
                </rule>

                <!--
                    Reverse-proxy /admin/console/{api,auth,health} to the
                    Node Express web-server on 127.0.0.1:3001 via ARR.
                    The {R:1} capture strips the /admin/console prefix so
                    express sees its native /api/* and /auth/* routes.
                    Must come BEFORE the SPA fallback below or API requests
                    would be served the React index.html instead.
                -->
                <rule name="Admin Console API proxy to express" stopProcessing="true">
                    <match url="^admin/console/(api/.*|auth/.*|health)$" />
                    <action type="Rewrite" url="http://127.0.0.1:3001/{R:1}" />
                </rule>

                <!--
                    React SPA fallback for the admin console.
                    Any /admin/console/path that isn't an actual file or directory
                    serves /admin/console/index.html so React Router (or tab state)
                    can take over. Static assets (JS/CSS/img) under
                    /admin/console/assets/ are still served directly because they
                    exist as files.
                -->
                <rule name="Admin Console SPA fallback" stopProcessing="true">
                    <match url="^admin/console/(.*)$" />
                    <conditions logicalGrouping="MatchAll">
                        <add input="{REQUEST_FILENAME}" matchType="IsFile"      negate="true" />
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
                    </conditions>
                    <action type="Rewrite" url="/admin/console/index.html" />
                </rule>
            </rules>
            <outboundRules>
                <rule name="Add Strict-Transport-Security" preCondition="HTTPSOnly">
                    <match serverVariable="RESPONSE_Strict_Transport_Security" pattern=".*" />
                    <action type="Rewrite" value="max-age=31536000; includeSubDomains" />
                </rule>
                <rule name="Add X-Content-Type-Options">
                    <match serverVariable="RESPONSE_X_Content_Type_Options" pattern=".*" />
                    <action type="Rewrite" value="nosniff" />
                </rule>
                <rule name="Add Referrer-Policy">
                    <match serverVariable="RESPONSE_Referrer_Policy" pattern=".*" />
                    <action type="Rewrite" value="strict-origin-when-cross-origin" />
                </rule>
                <preConditions>
                    <preCondition name="HTTPSOnly">
                        <add input="{HTTP_CF_VISITOR}" pattern='^\{.*"scheme":"https".*\}$' />
                    </preCondition>
                </preConditions>
            </outboundRules>
        </rewrite>
    </system.webServer>
</configuration>
