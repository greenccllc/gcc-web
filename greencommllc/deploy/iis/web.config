<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS reverse-proxy config for api.greencommllc.com.
  Forwards every request to the Node Express server running on
  http://127.0.0.1:3001 (the apps/web-server workspace).

  Requires:
    - URL Rewrite Module     (https://www.iis.net/downloads/microsoft/url-rewrite)
    - Application Request Routing (ARR)  (enable proxy in IIS Manager → ARR → Server Proxy Settings → Enable proxy)
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3001/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_ORIGINAL_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="{CACHE_URL:1}" />
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
          </serverVariables>
        </rule>
      </rules>
      <outboundRules>
        <preConditions>
          <preCondition name="ResponseIsHtml1">
            <add input="{RESPONSE_CONTENT_TYPE}" pattern="^text/html" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
    <security>
      <requestFiltering>
        <!-- Allow webhook payloads up to 5 MB -->
        <requestLimits maxAllowedContentLength="5242880" />
      </requestFiltering>
    </security>
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>
  </system.webServer>
</configuration>
