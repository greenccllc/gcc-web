{
  "name": "greencommllc",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web-server",
    "apps/web-client",
    "apps/proposal",
    "apps/calculator",
    "apps/desktop"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm -w apps/web-server run dev",
    "dev:client": "npm -w apps/web-client run dev",
    "dev:proposal": "npm -w apps/proposal run dev",
    "dev:calculator": "npm -w apps/calculator run dev",
    "build:client": "npm -w apps/web-client run build",
    "build:proposal": "npm -w apps/proposal run build",
    "build:calculator": "npm -w apps/calculator run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
