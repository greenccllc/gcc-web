{
  "name": "@gcc/proposal-components",
  "version": "0.1.0",
  "private": true,
  "description": "GCC proposal component library — React mirror of jinja/macros/all.html. Used as the target for Figma Code Connect mappings.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "cc:publish": "figma connect publish --token $FIGMA_TOKEN",
    "cc:parse":   "figma connect parse",
    "cc:unpublish": "figma connect unpublish --token $FIGMA_TOKEN"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  }
}
