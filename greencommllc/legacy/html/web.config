<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <defaultDocument>
            <files>
                <add value="bundle-builder.html" />
            </files>
        </defaultDocument>
        <staticContent>
            <mimeMap fileExtension=".gccjob" mimeType="application/octet-stream" />
            <clientCache cacheControlMode="DisableCache" />
        </staticContent>
    </system.webServer>
</configuration>
