{
  "name": "gcc-proposal-generator",
  "version": "0.1.0",
  "description": "GCC LLC proposal generator — TypeScript / Svelte rewrite of bundle-builder.html",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^20.12.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "mermaid": "^10.9.0",
    "pdf-lib": "^1.17.1"
  }
}
