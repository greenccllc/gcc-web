PORT=3001
# Comma-separated list of allowed CORS origins
CLIENT_ORIGIN=http://localhost:5174,http://localhost:5175,https://app.greencommllc.com

QB_CLIENT_ID=your_intuit_app_client_id
QB_CLIENT_SECRET=your_intuit_app_client_secret
QB_ENVIRONMENT=sandbox
QB_REDIRECT_URI=http://localhost:3001/auth/callback

APS_CLIENT_ID=your_autodesk_aps_client_id
APS_CLIENT_SECRET=your_autodesk_aps_client_secret
APS_SCOPES=data:read data:write bucket:read bucket:create

# Local MyAIDrive sync folder — files dropped here flow into the extractor.
MYAIDRIVE_PATH=C:\GCC LLC\MyAiDrive

# Google Gemini — extraction + stylizing client-facing output.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_EXTRACT_MODEL=gemini-2.5-flash
GEMINI_STYLE_MODEL=gemini-2.5-flash
