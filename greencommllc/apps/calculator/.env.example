# ─── core ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001
# Origins allowed to CORS / iframe-embed this app (frame-ancestors + CORS allowlist)
ALLOWED_PARENT_ORIGINS=http://localhost:3000,https://greencommllc.com,https://www.greencommllc.com

# ─── postgres ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://calc:calc_dev@localhost:5432/calc_app
# Used by docker compose
POSTGRES_USER=calc
POSTGRES_PASSWORD=calc_dev
POSTGRES_DB=calc_app

# ─── auth ─────────────────────────────────────────────────────────────────
# 32+ random bytes hex-encoded — used to sign session JWTs (cookie auth)
SESSION_SECRET=replace-me-with-openssl-rand-hex-32
# bcrypt cost factor (10 in dev, 12 in prod)
BCRYPT_ROUNDS=10
# Session cookie lifetime (seconds)
SESSION_TTL_SECONDS=2592000

# ─── google oauth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
# Optional: restrict OAuth signup to this Workspace domain (e.g. greencommllc.com)
# Leave blank to allow any Google account.
GOOGLE_HOSTED_DOMAIN=
